  "keyFeatures": [
    "Language-neutral serialization format: define data structures once, generate code for any supported language",
    "Multi-language runtime support: C++, Java, Python, C#, Go, Ruby, PHP, Objective-C, Rust",
    "Protocol compiler (protoc) generates efficient serialization/deserialization code",
    "Backward and forward compatible schema evolution",
    "Compact binary wire format for efficient network transmission",
    "Proto2 and proto3 syntax with optional field presence tracking",
    "Well-Known Types for common data structures (Timestamp, Duration, Any, Struct)",
    "JSON and TextFormat representations alongside binary format",
    "Arena allocation in C++ for high-performance memory management",
    "Editions system for fine-grained feature control across schema versions"
  ],
  "publicApiSurface": [
    "message: base type for all protobuf messages",
    "MessageLite: lightweight message base for mobile/embedded",
    "Descriptor / FileDescriptor: runtime schema reflection",
    "DynamicMessage: schema-driven messages without code generation",
    "TextFormat: human-readable serialization/deserialization",
    "JsonFormat (Java/C#): JSON serialization for protobuf messages",
    "protoc --cpp_out / --java_out / --python_out / --csharp_out / --go_out / --ruby_out / --php_out",
    "google.protobuf.Any: encapsulate arbitrary protobuf messages",
    "google.protobuf.Timestamp / Duration / Struct / Value / FieldMask",
    "RepeatedField<T> / RepeatedPtrField<T>: repeated field containers (C++)",
    "Arena: memory arena for C++ message allocation",
    "MessageFactory / DynamicMessageFactory: programmatic message construction"
  ]
}
